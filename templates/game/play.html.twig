{% extends 'base.html.twig' %}

{% block title %}MyUNO - Table de jeu{% endblock %}

{% block body %}

<h1>MyUNO</h1>

{% set gagnant = null %}
{% for joueur in game.joueurs %}
    {# Si ce joueur n'a plus de cartes, c'est lui le gagnant #}
    {% if joueur.cartes|length == 0 %}
        {% set gagnant = joueur %}
    {% endif %}
{% endfor %}

{# Si on a trouvé un gagnant, on affiche le message de victoire #}
{% if gagnant is not null %}
    <div class="message-victoire">
        🏆 {{ gagnant.nom }} a gagné la partie ! Félicitations !
    </div>
{% endif %}

{% set botActif = null %}
{% for joueur in game.joueurs %}
    {# Ce joueur est un bot ET c'est son tour ? #}
    {% if joueur.estHumain == false and joueur.position == game.tourActuel %}
        {% set botActif = joueur %}
    {% endif %}
{% endfor %}


{% if gagnant is null %}
    {% if estMonTour %}
        <div class="message-info">
            C'est votre tour ! Cliquez sur une carte pour la jouer.
        </div>
    {% else %}
        <div class="message-info">
            Tour de {{ botActif is not null ? botActif.nom : }}... Chargement dans <span id="compte-a-rebours">3</span> secondes.
        </div>

        <script>
            var idBot = {{ botActif is not null ? botActif.id : 'null' }};

            var secondes = 3; // Durée du compte à rebours en secondes temps de joueur bot

            var intervalle = setInterval(function() {
                secondes = secondes - 1;

                var compteur = document.getElementById('compte-a-rebours');
                if (compteur) {
                    compteur.textContent = secondes;
                }

                if (secondes <= 0) {
                    clearInterval(intervalle); // On arrête le compte à rebours

                    // On redirige vers /enemy avec l'id du bot
                    if (idBot !== null) {
                        window.location.href = '/enemy?id=' + idBot;
                    }
                }
            }, 1000);
        </script>
    {% endif %}
{% endif %}


<div class="zone-milieu">

    <div class="bloc-pile">
        <h2>Carte du dessus</h2>

        {% set couleurPile = pile.couleurSommet %}

        {% if couleurPile == 'rouge' %}
            {% set classeCouleurPile = 'couleur-rouge' %}
        {% elseif couleurPile == 'bleu' %}
            {% set classeCouleurPile = 'couleur-bleu' %}
        {% elseif couleurPile == 'vert' %}
            {% set classeCouleurPile = 'couleur-vert' %}
        {% elseif couleurPile == 'jaune' %}
            {% set classeCouleurPile = 'couleur-jaune' %}
        {% else %}
            {% set classeCouleurPile = 'couleur-autre' %}
        {% endif %}

        <div class="carte-pile {{ classeCouleurPile }}">
            <span>{{ pile.couleurSommet }}</span>
            <span>{{ pile.valeurSommet }}</span>
        </div>
    </div>

    <div class="bloc-bots">
        <h2>Bots adversaires</h2>

        {% for joueur in game.joueurs %}
            {% if joueur.estHumain == false %}

                    {# Si c'est le tour de ce bot, on lui ajoute la classe "son-tour" #}
                {% if joueur.position == game.tourActuel %}
                    <div class="joueur-bot son-tour">
                {% else %}
                    <div class="joueur-bot">
                {% endif %}

                    <span class="nom">{{ joueur.nom }}</span>

                    {# Le nombre de cartes restantes dans sa main #}
                    <span class="nb-cartes">{{ joueur.cartes|length }}</span>

                </div>

            {% endif %}
        {% endfor %}
    </div>

</div>

<div class="bloc-main">
    <h2>Vos cartes</h2>

    <div class="main-cartes">

        {# On parcourt toutes les cartes du joueur humain #}
        {% for carte in mainDuJoueur %}

            {# On choisit la classe CSS de fond selon la couleur de la carte #}
            {% if carte.couleur == 'rouge' %}
                {% set classeCouleur = 'couleur-rouge' %}
            {% elseif carte.couleur == 'bleu' %}
                {% set classeCouleur = 'couleur-bleu' %}
            {% elseif carte.couleur == 'vert' %}
                {% set classeCouleur = 'couleur-vert' %}
            {% elseif carte.couleur == 'jaune' %}
                {% set classeCouleur = 'couleur-jaune' %}
            {% else %}
                {% set classeCouleur = 'couleur-autre' %}
            {% endif %}

     
            {% set estJouable = cartesJouables[carte.id] %}

            {# Si c'est le tour du joueur ET que la carte est jouable : lien cliquable #}
            {% if estMonTour and estJouable %}
                {# Le joueur clique sur la carte → redirige vers /player?id=X #}
                <a href="{{ path('app_player', {id: carte.id}) }}"
                   class="carte-bouton {{ classeCouleur }}">
                    <span>{{ carte.couleur }}</span>
                    <span>{{ carte.valeur }}</span>
                </a>

            {% else %}
                {# Carte non jouable ou ce n'est pas le tour : carte grisée, non cliquable #}
                <div class="carte-bouton {{ classeCouleur }} non-jouable">
                    <span>{{ carte.couleur }}</span>
                    <span>{{ carte.valeur }}</span>
                </div>

            {% endif %}

        {% else %}
            {# Ce message s'affiche si le joueur n'a plus aucune carte #}
            <p>Vous n'avez plus de cartes !</p>
        {% endfor %}

    </div>

    {# Bouton piocher : visible seulement si c'est le tour du joueur et qu'aucune carte n'est jouable #}
    {% if estMonTour %}
        {% set uneCarteJouable = false %}
        {% for carte in mainDuJoueur %}
            {% if cartesJouables[carte.id] %}
                {% set uneCarteJouable = true %}
            {% endif %}
        {% endfor %}

        {% if not uneCarteJouable %}
            <a href="{{ path('app_draw') }}">Piocher une carte</a>
        {% endif %}
    {% endif %}

</div>

<a href="{{ path('app_home') }}" class="lien-retour">← Retour à l'accueil</a>

{% endblock %}
