{% extends 'base.html.twig' %}

{% block title %}MyUNO - Table de jeu{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/jeu.css') }}">
{% endblock %}

{% block body %}

<h1>MyUNO</h1>

{% set gagnant = null %}
{% for joueur in game.joueurs %}
    {# si le joueur na plu de carte il a gagner #}
    {% if joueur.cartes|length == 0 %}
        {% set gagnant = joueur %}
    {% endif %}
{% endfor %}

{# si on a trouver un gagnant on le redirige vers les resultat #}
{% if gagnant is not null or game.statut == 'termine' %}
    <script>window.location.href = "{{ path('app_result') }}";</script>
{% endif %}

{% set botActif = null %}
{% for joueur in game.joueurs %}
     
    {% if joueur.estHumain == false and joueur.position == game.tourActuel %}
        {% set botActif = joueur %}
    {% endif %}
{% endfor %}


{% if gagnant is null and game.statut == 'en_cours' %}
    {% if estMonTour %}
        <div class="message-info">
            C'est votre tour ! Cliquez sur une carte pour la jouer.
        </div>
    {% else %}
        <div class="message-info">
            Tour de {{ botActif is not null ? botActif.nom :'' }}... Chargement dans <span id="compte-a-rebours">3</span> secondes.
        </div>

        <script>
            var idBot = {{ botActif is not null ? botActif.id : 'null' }};

            var secondes = 3; // le temps que le bot attend avan de jouer

            var intervalle = setInterval(function() {
                secondes = secondes - 1;

                var compteur = document.getElementById('compte-a-rebours');
                if (compteur) {
                    compteur.textContent = secondes;
                }

                if (secondes <= 0) {
                    clearInterval(intervalle); // on arrete le compte a rebour

                    // on redirige ver /enemy avec lid du bot
                    if (idBot !== null) {
                        window.location.href = '/enemy?id=' + idBot;
                    }
                }
            }, 1000);
        </script>
    {% endif %}
{% endif %}


{# on recupere les 3 bots dans lordre #}
{% set bots = [] %}
{% for joueur in game.joueurs %}
    {% if joueur.estHumain == false %}
        {% set bots = bots|merge([joueur]) %}
    {% endif %}
{% endfor %}

<div class="table-jeu">

    {# le bot en haut (en face) #}
    <div class="bot-face">
        {% if bots[1] is defined %}
            <div class="bloc-bot {% if bots[1].position == game.tourActuel %}son-tour{% endif %}">
                <span class="bot-nom">{{ bots[1].nom }}</span>
                <span class="bot-cartes">{{ bots[1].cartes|length }}</span>
            </div>
        {% endif %}
    </div>

    {# la ligne du millieu avec le bot a gauche la pile au milieu et le bot a droite #}
    <div class="ligne-milieu">

        <div class="bot-gauche">
            {% if bots[0] is defined %}
                <div class="bloc-bot {% if bots[0].position == game.tourActuel %}son-tour{% endif %}">
                    <span class="bot-nom">{{ bots[0].nom }}</span>
                    <span class="bot-cartes"> {{ bots[0].cartes|length }}</span>
                </div>
            {% endif %}
        </div>

        <div class="bloc-pile">
            {% set couleurPile = pile.couleurSommet %}
            {% if couleurPile == 'rouge' %}
                {% set classeCouleurPile = 'couleur-rouge' %}
            {% elseif couleurPile == 'bleu' %}
                {% set classeCouleurPile = 'couleur-bleu' %}
            {% elseif couleurPile == 'vert' %}
                {% set classeCouleurPile = 'couleur-vert' %}
            {% elseif couleurPile == 'jaune' %}
                {% set classeCouleurPile = 'couleur-jaune' %}
            {% else %}
                {% set classeCouleurPile = 'couleur-autre' %}
            {% endif %}

            <h2>Carte du dessus</h2>
            <div class="piles-container">
                <div class="carte-pile {{ classeCouleurPile }}">
                    <span>{{ pile.couleurSommet }}</span>
                    <span>{{ pile.valeurSommet }}</span>
                </div>

                {% if estMonTour and game.statut == 'en_cours' %}
                    {% set uneCarteJouable = false %}
                    {% for carte in mainDuJoueur %}
                        {% if cartesJouables[carte.id] %}
                            {% set uneCarteJouable = true %}
                        {% endif %}
                    {% endfor %}
                    {% if not uneCarteJouable %}
                        <a href="{{ path('app_draw') }}" class="bouton-pioche">Piocher une carte</a>
                    {% endif %}
                {% endif %}
            </div>
        </div>

        <div class="bot-droite">
            {% if bots[2] is defined %}
                <div class="bloc-bot {% if bots[2].position == game.tourActuel %}son-tour{% endif %}">
                    <span class="bot-nom">{{ bots[2].nom }}</span>
                    <span class="bot-cartes"> {{ bots[2].cartes|length }}</span>
                </div>
            {% endif %}
        </div>

    </div>

</div>

<div class="bloc-main">
    <h2>Vos cartes ({{ mainDuJoueur|length }})</h2>

    <div class="main-cartes">

        {% for carte in mainDuJoueur %}

            {% if carte.couleur == 'rouge' %}
                {% set classeCouleur = 'couleur-rouge' %}
            {% elseif carte.couleur == 'bleu' %}
                {% set classeCouleur = 'couleur-bleu' %}
            {% elseif carte.couleur == 'vert' %}
                {% set classeCouleur = 'couleur-vert' %}
            {% elseif carte.couleur == 'jaune' %}
                {% set classeCouleur = 'couleur-jaune' %}
            {% else %}
                {% set classeCouleur = 'couleur-autre' %}
            {% endif %}

            {% set estJouable = cartesJouables[carte.id] %}

                {# si la partie est finit on grise la carte et on peut pas cliquer dessus #}
            {% if game.statut == 'termine' %}
                <div class="carte-bouton {{ classeCouleur }} non-jouable">
                    <span>{{ carte.couleur }}</span>
                    <span>{{ carte.valeur }}</span>
                </div>
            {# si cest notre tour et que la carte est jouable on met un lien cliquable #}
            {% elseif estMonTour and estJouable %}

                <a href="{{ path('app_player', {id: carte.id}) }}"
                   class="carte-bouton {{ classeCouleur }}">
                    <span>{{ carte.couleur }}</span>
                    <span>{{ carte.valeur }}</span>
                </a>

            {% else %}

                <div class="carte-bouton {{ classeCouleur }} non-jouable">
                    <span>{{ carte.couleur }}</span>
                    <span>{{ carte.valeur }}</span>
                </div>

            {% endif %}

        {% else %}
            <p>Vous n'avez plus de cartes !</p>
        {% endfor %}
    </div>


</div>

<a href="{{ path('app_home') }}" class="lien-retour">← Abandonner la partie</a>

{% endblock %}
